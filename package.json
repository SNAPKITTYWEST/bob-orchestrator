{
  "name": "@snapkitty/bob-orchestrator",
  "version": "0.1.0",
  "description": "BOB — sovereign orchestrator. Lean 4 proof gates + Ada contracts + Mamba SSM injections + Prolog kernel. Not an LLM wrapper. A reasoning machine.",
  "type": "module",
  "main": "core/bob.mjs",
  "scripts": {
    "start":      "node core/bob.mjs",
    "test":       "node core/bob.mjs --test",
    "lean-check": "lean lean4/SovereignGate.lean",
    "demo":       "node bridge/demo.mjs",
    "tessera":    "node tessera/tessera_demo.mjs",
    "studio":     "node tessera/studio_server.mjs",
    "gitdos":     "node tessera/studio_server.mjs",
    "nil":        "node autonomous/holyc_nil.mjs",
    "emoji":      "node autonomous/emoji_trigger.mjs",
    "agent":      "node autonomous/autonomous_agent.mjs",
    "compare":    "node autonomous/compare.mjs",
    "chat":       "node autonomous/chat.mjs",
    "dict":       "node autonomous/dictionary.mjs",
    "img2ascii":  "python ascii/img2ascii.py",
    "ascii3d":    "python ascii/ascii3d.py",
    "ascii":      "node ascii/bob_ascii.mjs"
  },
  "dependencies": {
    "@snapkitty/mcp-server": "file:../snapkitty-mcp"
  },
  "keywords": [
    "sovereign",
    "orchestrator",
    "mamba",
    "ssm",
    "lean4",
    "ada",
    "prolog",
    "nemotron",
    "bob"
  ],
  "author": "SnapKitty Collective <collective@snapkitty.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/SNAPKITTYWEST/bob-orchestrator.git"
  }
}
